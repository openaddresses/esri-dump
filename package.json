{
    "name": "esri-dump",
    "type": "module",
    "version": "6.2.0",
    "author": "Ian Dees <ian.dees@gmail.com>",
    "description": "Assist with pulling data out of an ESRI ArcGIS REST server into a more useful format.",
    "scripts": {
        "test": "tsx --test test/*.test.ts",
        "build": "tsc --build && cp lib/wkid.json dist/lib/wkid.json",
        "lint": "eslint *.ts test/*.ts lib/*.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/openaddresses/esri-dump.git"
    },
    "bin": {
        "esri-dump": "./dist/cli.js"
    },
    "main": "dist/index.js",
    "types": "index.ts",
    "license": "MIT",
    "engines": {
        "node": ">=24"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/geojson": "^7946.0.10",
        "eslint": "^10.0.0",
        "geojsonhint": "^2.0.0",
        "tsx": "^4.20.6",
        "typescript": "^6.0.0",
        "typescript-eslint": "^8.0.0"
    },
    "dependencies": {
        "@openaddresses/batch-error": "^2.2.0",
        "@types/json-schema": "^7.0.12",
        "proj4": "^2.20.4"
    }
}
